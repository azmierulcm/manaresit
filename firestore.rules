rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && request.auth.uid == resource.data.userId;
    }

    function ownsNewDoc() {
      return signedIn() && request.auth.uid == request.resource.data.userId;
    }

    match /users/{uid} {
      allow read, update, delete: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
    }

    match /transactions/{transactionId} {
      allow read, delete: if ownsExistingDoc();
      allow update: if ownsExistingDoc()
        && request.resource.data.userId == resource.data.userId;
      allow create: if ownsNewDoc();
    }

    match /receipts/{receiptId} {
      allow read, delete: if ownsExistingDoc();
      allow update: if ownsExistingDoc()
        && request.resource.data.userId == resource.data.userId;
      allow create: if ownsNewDoc();
    }

    match /einvoices/{einvoiceId} {
      allow read, delete: if ownsExistingDoc();
      allow update: if ownsExistingDoc()
        && request.resource.data.userId == resource.data.userId;
      allow create: if ownsNewDoc();
    }

    match /reports/{reportId} {
      allow read, delete: if ownsExistingDoc();
      allow update: if ownsExistingDoc()
        && request.resource.data.userId == resource.data.userId;
      allow create: if ownsNewDoc();
    }
  }
}
