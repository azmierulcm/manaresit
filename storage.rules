rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{uid}/receipts/{receiptId}.avif {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/reports/{reportId}/{fileName} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }
  }
}
